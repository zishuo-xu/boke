# 应用配置
APP_NAME=股票/基金数据监控面板
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置
DATABASE_URL=sqlite:///./data/finance.db

# JWT配置
SECRET_KEY=your-secret-key-change-in-production-123456
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS配置
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]

# Claude API配置（预留）
CLAUDE_API_KEY=

# 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
