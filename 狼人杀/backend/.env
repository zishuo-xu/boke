# GLM模型配置模板
# 复制此文件为 .env 并填入你的API密钥

# LLM Provider选择
# 可选值: mock, glm, openai, anthropic
LLM_PROVIDER=glm

# GLM API Key (智谱AI)
# 在 https://open.bigmodel.cn/ 获取
GLM_API_KEY=20b28c25d9894302990ebbef5f818d71.SbuZQrHq821YWi2A

# 默认模型
# 可选: glm-4-plus, glm-4, glm-4-flash, glm-4-air, glm-4-long, glm-3-turbo
DEFAULT_MODEL=glm-4-plus

# 游戏速度
# 可选: slow, medium, fast
GAME_SPEED=medium

# 其他LLM配置（如需使用其他模型）
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
